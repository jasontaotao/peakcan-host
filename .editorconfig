root = true
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{cs,xaml}]
trim_trailing_whitespace = true
dotnet_diagnostic.IDE0005.severity = none
dotnet_diagnostic.CA1822.severity = none
# Allow plural flag-enum type names (BindingFlags / FrameFlags idiom).
dotnet_diagnostic.CA1711.severity = none
# "Error" collides with VB.NET reserved keyword; this is a C#-only project.
dotnet_diagnostic.CA1716.severity = none
# Result<T>.Ok / .Fail are intentional static factories — discriminated-union pattern.
dotnet_diagnostic.CA1000.severity = none
# TokenType.Keyword_BO_, _SG_, _BS_, _NS_DESC_ etc. — underscores ARE the lexeme,
# matching the actual DBC grammar. CA1707 / CA1720 (Integer, String match BCL type names).
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1720.severity = none

[*.Tests.cs]
# xUnit convention: underscored BDD-style test method names (Method_Condition_Expected).
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1014.severity = none
