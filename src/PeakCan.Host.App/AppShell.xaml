<Window x:Class="PeakCan.Host.App.AppShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PeakCan.Host.App"
        xmlns:views="clr-namespace:PeakCan.Host.App.Views"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="720" Width="1280">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Open DBC..." Command="{Binding OpenDbcCommand}" />
                <Separator />
                <MenuItem Header="Open _Session..." Command="{Binding OpenSessionCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="_Save Session..." Command="{Binding SaveSessionCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Open _Recent" ItemsSource="{Binding RecentSessionEntries}">
                    <MenuItem.ItemTemplate>
                        <DataTemplate>
                            <MenuItem Header="{Binding Label}"
                                      Command="{Binding DataContext.OpenRecentSessionCommand,
                                                        RelativeSource={RelativeSource AncestorType=Menu}}"
                                      CommandParameter="{Binding Path}" />
                        </DataTemplate>
                    </MenuItem.ItemTemplate>
                </MenuItem>
                <MenuItem Header="_Clear Recent" Command="{Binding ClearRecentSessionsCommand}" />
                <Separator />
                <MenuItem Header="Exit" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Trace" Command="{Binding ShowTraceCommand}" />
                <MenuItem Header="DBC" Command="{Binding ShowDbcCommand}" />
                <MenuItem Header="Send" Command="{Binding ShowSendCommand}" />
                <MenuItem Header="Signals" Command="{Binding ShowSignalsCommand}" />
                <MenuItem Header="Stats" Command="{Binding ShowStatsCommand}" />
                <MenuItem Header="Script" Command="{Binding ShowScriptCommand}" />
                <MenuItem Header="UDS" Command="{Binding ShowUdsCommand}" />
                <MenuItem Header="Replay" Command="{Binding ShowReplayCommand}" />
                <MenuItem Header="Trace Viewer…" Command="{Binding ShowTraceViewerCommand}" />
                <MenuItem Header="Multi-frame..." Command="{Binding OpenMultiFrameCommand}" />
            </MenuItem>
        </Menu>
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <TextBlock Text="{Binding ChannelList}" VerticalAlignment="Center" Margin="4,0" />
                <Separator />
                <Button Content="Probe" Command="{Binding EnumerateChannelsCommand}" Padding="6,2" />
                <!-- v0.4.0: channel selector (visible after probe) -->
                <ComboBox ItemsSource="{Binding AvailableChannels}"
                          SelectedItem="{Binding SelectedChannel}"
                          DisplayMemberPath="Name"
                          IsEnabled="{Binding IsDisconnected}"
                          Width="140" VerticalAlignment="Center" />
                <Separator />
                <CheckBox Content="CAN FD" IsChecked="{Binding IsFd}"
                          IsEnabled="{Binding IsDisconnected}" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding AvailableBaudRates}"
                          SelectedItem="{Binding SelectedBaudRate}"
                          DisplayMemberPath="Name"
                          IsEnabled="{Binding IsDisconnected}"
                          Width="120" VerticalAlignment="Center" />
                <Separator />
                <Button Content="Connect" Command="{Binding ConnectCommand}" Padding="6,2" />
                <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Padding="6,2" />
                <Separator />
                <!-- v3.50.1 PATCH-A: Recording moved to a public AppShell
                     toolbar location. Replaces v3.49 Q2's Trace Viewer
                     Expander (conflated playback with capture) and the
                     v3.50.1 first-draft tab. Permanent button + docked
                     panel below the content area — accessible from every
                     tab without leaving the active surface. -->
                <ToggleButton Content="● Record"
                              IsChecked="{Binding IsRecordingPanelOpen, Mode=TwoWay}"
                              Padding="6,2"
                              ToolTip="Show / hide the Recording panel (Ctrl+R)" />
                <Separator />
                <TextBlock Text="{Binding ConnectionState}" VerticalAlignment="Center" Margin="4,0" />
            </ToolBar>
        </ToolBarTray>
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusMessage}" />
        </StatusBar>
        <!-- v3.50.1 PATCH-A: Recording panel as a docked Expander. Always
             mounted (cheap), only expanded when the toolbar toggle is on.
             DataContext = RecordingPanel (the RecordViewModel singleton
             wired in via DI). Shared by all tabs — the panel survives
             CurrentView swaps. -->
        <!-- v3.50.1 PATCH-A: Always-mounted Recording Expander. Toolbar
             ToggleButton's IsChecked drives IsRecordingPanelOpen which
             both expands/collapses the expander. The expander is
             always present (collapsed = 0 vertical space); visibility
             and height collapse automatically. -->
        <Expander DockPanel.Dock="Bottom"
                  Header="Recording"
                  IsExpanded="{Binding IsRecordingPanelOpen}">
            <views:RecordView DataContext="{Binding RecordingPanel}" />
        </Expander>
        <ContentControl Content="{Binding CurrentView}" />
    </DockPanel>
</Window>
