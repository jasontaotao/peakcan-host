<Window x:Class="PeakCan.Host.App.Windows.MultiFrameSendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PeakCan.Host.App.ViewModels"
        xmlns:m="clr-namespace:PeakCan.Host.App.Models"
        xmlns:conv="clr-namespace:PeakCan.Host.App.Composition.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MultiFrameSendViewModel}"
        Title="Multi-frame send"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True"
        Topmost="False">
    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBool" />
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Frame list DataGrid -->
        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID (hex)" Binding="{Binding IdHexDisplay, Mode=OneWay}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" />
                <DataGridTextColumn Header="Data (hex)" Binding="{Binding DataHex}" Width="*" />
                <DataGridCheckBoxColumn Header="Ext" Binding="{Binding IsExtended}" Width="50" />
                <DataGridCheckBoxColumn Header="FD"  Binding="{Binding IsFd}" Width="50" />
                <DataGridCheckBoxColumn Header="RTR" Binding="{Binding IsRtr}" Width="50" />
                <DataGridCheckBoxColumn Header="BRS" Binding="{Binding IsBitRateSwitch}" Width="50" />
                <DataGridCheckBoxColumn Header="ESI" Binding="{Binding IsErrorStateIndicator}" Width="50" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Toolbar -->
        <DockPanel Grid.Row="1" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Add"     Command="{Binding AddRowCommand}"      Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="Remove"    Command="{Binding RemoveRowCommand}"   Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="Duplicate" Command="{Binding DuplicateRowCommand}" Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="▲ Up"      Command="{Binding MoveUpCommand}"      Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="▼ Down"    Command="{Binding MoveDownCommand}"    Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="Clear all" Command="{Binding ClearRowsCommand}"   Padding="8,3" Margin="0,0,16,0"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                       DockPanel.Dock="Right" Margin="8,0,0,0" Foreground="Gray"/>
        </DockPanel>

        <!-- Mode + Run row -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <RadioButton Grid.Column="1" Content="Concurrent" GroupName="Mode"
                         IsChecked="{Binding IsConcurrent}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <RadioButton Grid.Column="2" Content="Sequential" GroupName="Mode"
                         IsChecked="{Binding IsConcurrent, Converter={StaticResource InverseBool}}"
                         VerticalAlignment="Center" Margin="0,0,12,0"/>

            <TextBlock Grid.Column="3" Text="Delay (ms):" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox Grid.Column="4" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}"
                     Width="60" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="6" Orientation="Horizontal">
                <TextBlock Text="Iterations:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding Iterations, UpdateSourceTrigger=PropertyChanged}"
                         Width="60" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="▶ Send" Command="{Binding SendCommand}" Padding="10,3" Margin="0,0,4,0"/>
                <Button Content="⏹ Stop" Command="{Binding StopCommand}" Padding="10,3" Margin="0,0,4,0"/>
                <Button Content="Close" Click="OnCloseClick" Padding="10,3"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>