<Window x:Class="PeakCan.Host.App.Windows.MultiFrameSendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PeakCan.Host.App.ViewModels"
        xmlns:m="clr-namespace:PeakCan.Host.App.Models"
        xmlns:conv="clr-namespace:PeakCan.Host.App.Composition.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MultiFrameSendViewModel}"
        Title="Multi-frame send"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True"
        Topmost="False">
    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBool" />
        <!-- v2.1.1 PATCH: visibility converter for "kind == X" bindings -->
        <conv:KindEqualsConverter x:Key="KindEquals" />
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Frame list DataGrid -->
        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  RowDetailsVisibilityMode="VisibleWhenSelected">
            <DataGrid.Columns>
                <!-- v2.1.1 PATCH: Type column with Raw/Dbc dropdown.
                     Switching a row's Kind toggles the RowDetails
                     editor via the DataTrigger on RowKind below. -->
                <DataGridTextColumn Header="ID (hex)" Binding="{Binding IdHexDisplay, Mode=OneWay}" Width="80" IsReadOnly="True"/>
                <DataGridComboBoxColumn Header="Type" Width="70"
                                        SelectedItemBinding="{Binding RowKind}">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding DataContext.AvailableDbcMessages, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                </DataGridComboBoxColumn>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" />
                <DataGridTextColumn Header="Data (hex)" Binding="{Binding DataHex}" Width="*" />
                <DataGridCheckBoxColumn Header="Ext" Binding="{Binding IsExtended}" Width="40" />
                <DataGridCheckBoxColumn Header="FD"  Binding="{Binding IsFd}" Width="40" />
                <DataGridCheckBoxColumn Header="RTR" Binding="{Binding IsRtr}" Width="40" />
                <DataGridCheckBoxColumn Header="BRS" Binding="{Binding IsBitRateSwitch}" Width="40" />
                <DataGridCheckBoxColumn Header="ESI" Binding="{Binding IsErrorStateIndicator}" Width="40" />
            </DataGrid.Columns>

            <!-- v2.1.1 PATCH: RowDetails shows DBC editor when row
                 is Dbc kind; hidden for Raw. The editor is a small
                 grid: message picker + signal values. -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Padding="8" Background="#1E1E1E" BorderBrush="#444" BorderThickness="0,1,0,0">
                        <StackPanel Visibility="{Binding RowKind, Converter={StaticResource KindEquals}, ConverterParameter=Dbc}">
                            <TextBlock Text="DBC message" Foreground="#CCC" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DataContext.AvailableDbcMessages, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding DbcMessageName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="Name"
                                      Width="200" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Signal values" Foreground="#CCC" Margin="0,4,0,4"/>
                            <DataGrid ItemsSource="{Binding DbcSignalValues}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="True" CanUserDeleteRows="True"
                                      MaxHeight="160"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Signal" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Engineering value" Binding="{Binding Value}" Width="160" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <!-- Toolbar -->
        <DockPanel Grid.Row="1" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Add"     Command="{Binding AddRowCommand}"      Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="Remove"    Command="{Binding RemoveRowCommand}"   Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="Duplicate" Command="{Binding DuplicateRowCommand}" Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="▲ Up"      Command="{Binding MoveUpCommand}"      Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="▼ Down"    Command="{Binding MoveDownCommand}"    Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="Clear all" Command="{Binding ClearRowsCommand}"   Padding="8,3" Margin="0,0,16,0"/>
                <!-- v2.1.2 PATCH: saved-sequence picker + Save / Load / Delete -->
                <ComboBox ItemsSource="{Binding SavedSequences}"
                          SelectedItem="{Binding SelectedSavedSequence}"
                          DisplayMemberPath="Name"
                          Width="160" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Button Content="Load"   Command="{Binding LoadSavedCommand}"
                        CommandParameter="{Binding SelectedSavedSequence}"
                        Padding="8,3" Margin="0,0,4,0"/>
                <Button Content="Delete" Command="{Binding DeleteSavedCommand}"
                        CommandParameter="{Binding SelectedSavedSequence}"
                        Padding="8,3" Margin="0,0,4,0"/>
                <TextBox Text="{Binding SaveNameText, UpdateSourceTrigger=PropertyChanged}"
                         Width="120" VerticalAlignment="Center" Margin="0,0,4,0"
                         ToolTip="Name for the saved sequence"/>
                <Button Content="💾 Save current" Command="{Binding SaveCurrentCommand}"
                        Padding="8,3" Margin="0,0,4,0"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                       DockPanel.Dock="Right" Margin="8,0,0,0" Foreground="Gray"/>
            <!-- v3.0.9 PATCH: mirror of MultiFrameSendViewModel.RateLimitRejectedCount.
                 Same yellow chip pattern as v3.0.8 SendViewModel + v3.0.9 DbcSendViewModel
                 chips. Hidden when count = 0. Multi-frame is the highest-throughput caller,
                 so this chip is most likely to be non-zero during tight MaxFramesPerSecond caps. -->
            <Border DockPanel.Dock="Right" Margin="8,0,0,0" Padding="6,2" CornerRadius="3"
                    Background="#FFF8E1" BorderBrush="#D4A72C" BorderThickness="1"
                    Visibility="{Binding RateLimitRejectedVisibility}">
                <TextBlock VerticalAlignment="Center" Foreground="#7D4E00" FontSize="12">
                    <Run Text="rate limit rejected: " />
                    <Run Text="{Binding RateLimitRejectedCount, Mode=OneWay}" />
                </TextBlock>
            </Border>
        </DockPanel>

        <!-- Mode + Run row -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <RadioButton Grid.Column="1" Content="Concurrent" GroupName="Mode"
                         IsChecked="{Binding IsConcurrent}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <RadioButton Grid.Column="2" Content="Sequential" GroupName="Mode"
                         IsChecked="{Binding IsConcurrent, Converter={StaticResource InverseBool}}"
                         VerticalAlignment="Center" Margin="0,0,12,0"/>

            <TextBlock Grid.Column="3" Text="Delay (ms):" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox Grid.Column="4" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}"
                     Width="60" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="6" Orientation="Horizontal">
                <TextBlock Text="Iterations:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding Iterations, UpdateSourceTrigger=PropertyChanged}"
                         Width="60" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="▶ Send" Command="{Binding SendCommand}" Padding="10,3" Margin="0,0,4,0"/>
                <Button Content="⏹ Stop" Command="{Binding StopCommand}" Padding="10,3" Margin="0,0,4,0"/>
                <Button Content="Close" Click="OnCloseClick" Padding="10,3"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>