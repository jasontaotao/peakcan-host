<UserControl x:Class="PeakCan.Host.App.Views.ScriptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Margin="4">
            <Button Content="▶ Run"
                    Command="{Binding RunCommand}"
                    ToolTip="Run the script (Ctrl+Enter)"
                    Padding="8,4" />
            <Button Content="⏹ Stop"
                    Command="{Binding StopCommand}"
                    ToolTip="Stop the running script"
                    Padding="8,4" />
            <Separator />
            <Button Content="📂 Open"
                    Command="{Binding OpenCommand}"
                    ToolTip="Open a script file"
                    Padding="8,4" />
            <Button Content="💾 Save"
                    Command="{Binding SaveCommand}"
                    ToolTip="Save the current script"
                    Padding="8,4" />
            <Separator />
            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       Foreground="Gray" />
        </ToolBar>

        <!-- CodeMirror Editor -->
        <Grid Grid.Row="1" Margin="4">
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                <wv2:WebView2 x:Name="EditorWebView"
                              CoreWebView2InitializationCompleted="EditorWebView_CoreWebView2InitializationCompleted" />
            </Border>
        </Grid>

        <!-- Output Panel -->
        <Grid Grid.Row="2" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                <TextBlock Text="Output"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
                <Button Content="Clear"
                        Command="{Binding ClearOutputCommand}"
                        HorizontalAlignment="Right"
                        Padding="8,2" />
            </DockPanel>

            <Border Grid.Row="1"
                    BorderBrush="Gray" BorderThickness="1" CornerRadius="4"
                    Background="#1E1E1E">
                <ListBox ItemsSource="{Binding OutputLines}"
                         Background="Transparent"
                         Foreground="#D4D4D4"
                         FontFamily="Consolas"
                         FontSize="12"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectedIndex="-1" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
