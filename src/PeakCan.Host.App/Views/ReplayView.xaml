<UserControl x:Class="PeakCan.Host.App.Views.ReplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PeakCan.Host.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:ReplayViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d">
    <!--
        v3.8.0 MINOR chunk 3: InputBindings for frame stepping. The
        KeyBinding element style is preferred over KeyDown handlers
        because (a) the gesture + Command data-bind cleanly together,
        (b) the Slider focused-state keeps arrow-key behavior for
        scrubbing (Slider consumes the gesture; user taps the trace
        canvas to use frame-step), and (c) the pattern matches the
        existing Command="{Binding XxxCommand}" buttons. Ctrl+B for
        AddBookmark is added in chunk 5.
    -->
    <UserControl.InputBindings>
        <KeyBinding Key="Right" Command="{Binding NextFrameCommand}" />
        <KeyBinding Key="Left" Command="{Binding PrevFrameCommand}" />
        <!-- v3.8.0 MINOR chunk 5: Ctrl+B captures a bookmark at the current cursor. -->
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding AddBookmarkCommand}" />
    </UserControl.InputBindings>

    <!--
        v1.4.0 MINOR Task 4 + v1.5.0 MINOR Task 5: minimal Replay tab
        scaffold. Production polish (column headers, frame table, error
        retry button, etc.) is deferred per plan §文件结构.
        Bindings:
          OpenCommand / PlayCommand / PauseCommand / StopCommand /
          SetSpeedCommand / SeekToCommand are RelayCommands on
          ReplayViewModel (CommunityToolkit.Mvvm source generators).
          ErrorMessage's Visibility goes through NullToVisibilityConverter
          (registered in App.xaml) so it collapses when the property is
          null or empty.
          IsLoaded gates Play + the scrubber so the transport bar is
          inert before a file is loaded. Stop and Pause remain enabled
          after Stop (Stop resets IsLoaded? — no, only Open clears it).
          Loop CheckBox + CanIdFilter TextBox (v1.5.0 MINOR Task 5):
          Loop proxies through to IReplayService.Loop. CanIdFilterText
          uses UpdateSourceTrigger=PropertyChanged so the parser runs
          on every keystroke; CanIdFilterError surfaces inline parse
          failures without blocking valid tokens.
    -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <!-- v3.8.0 MINOR chunk 9: row 6 reserved for the
                 Bookmarks + Loop Regions side-by-side panels. -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--
            v3.7.0 MINOR Chunk 2: toolbar grew from 1 to 4 buttons:
              Open...     - dialog-driven raw ASC load (v1.4.0)
              Save...     - bundle save (chunk 1, exposed via VM command)
              Open session... - dialog-driven bundle open (chunk 1)
              Open recent - dropdown menu of recent bundles (chunk 2)
            Enable rules: Open.../Open session/Open recent are disabled
            while a session is loaded (the file dialog would be a no-op
            because IsLoaded gates the transport bar); Save... is only
            enabled once there's a file to snapshot. LoadedFilePath is
            shrunk from the explicit-margin block to fit the wider
            toolbar.
        -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Open..." Command="{Binding OpenCommand}" Margin="0,0,5,0"
                    IsEnabled="{Binding IsNotLoaded}"/>
            <Button Content="Save session..." Command="{Binding SaveCommand}" Padding="6,2" Margin="0,0,5,0"
                    IsEnabled="{Binding IsLoaded}"/>
            <Button Content="Open session..." Command="{Binding OpenSessionCommand}" Padding="6,2" Margin="0,0,5,0"
                    IsEnabled="{Binding IsNotLoaded}"/>
            <Button Content="Open recent" Click="OnOpenRecentClick" Padding="6,2" Margin="0,0,5,0"
                    IsEnabled="{Binding IsNotLoaded}"/>
            <TextBlock Text="{Binding LoadedFilePath}" VerticalAlignment="Center" Margin="5,0,10,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Play" Command="{Binding PlayCommand}" Margin="0,0,5,0"
                    IsEnabled="{Binding IsLoaded}"/>
            <Button Content="Pause" Command="{Binding PauseCommand}" Margin="0,0,5,0"
                    IsEnabled="{Binding IsLoaded}"/>
            <Button Content="Stop" Command="{Binding StopCommand}" Margin="0,0,5,0"
                    IsEnabled="{Binding IsLoaded}"/>
            <!-- v3.8.0 MINOR chunk 9: frame-step buttons. v3.8.1 PATCH:
                 IsEnabled bound to <Cmd>.CanExecute (CommunityToolkit.Mvvm
                 source-generated bool property on IRelayCommand) so the
                 buttons visually enable/disable at the right moments.
                 Pairs with [NotifyCanExecuteChangedFor] on _isLoaded +
                 _isPlaying in ReplayViewModel.cs. -->
            <Separator Margin="8,0,8,0"/>
            <Button Content="|◀" Command="{Binding PrevFrameCommand}" Margin="0,0,5,0"
                    ToolTip="Previous frame (Left arrow)"
                    IsEnabled="{Binding PrevFrameCommand.CanExecute, Mode=OneWay}"
                    Padding="6,2"/>
            <Button Content="▶|" Command="{Binding NextFrameCommand}" Margin="0,0,5,0"
                    ToolTip="Next frame (Right arrow)"
                    IsEnabled="{Binding NextFrameCommand.CanExecute, Mode=OneWay}"
                    Padding="6,2"/>
            <Separator Margin="8,0,8,0"/>
            <Button Content="+ Bookmark" Command="{Binding AddBookmarkCommand}" Margin="0,0,5,0"
                    ToolTip="Add bookmark at cursor (Ctrl+B)"
                    IsEnabled="{Binding AddBookmarkCommand.CanExecute, Mode=OneWay}"
                    Padding="6,2"/>
            <Button Content="+ Loop region" Command="{Binding AddLoopRegionCommand}" Margin="0,0,5,0"
                    ToolTip="Add loop region from current Start/End bounds"
                    IsEnabled="{Binding AddLoopRegionCommand.CanExecute, Mode=OneWay}"
                    Padding="6,2"/>
            <Button Content="Clear regions" Command="{Binding ClearLoopRegionsCommand}" Margin="0,0,5,0"
                    IsEnabled="{Binding ClearLoopRegionsCommand.CanExecute, Mode=OneWay}"
                    Padding="6,2"/>
            <TextBlock Text="{Binding CurrentTimestamp, StringFormat='{}{0:F2} s'}"
                       VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBlock Text="/" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBlock Text="{Binding TotalDuration, StringFormat='{}{0:F2} s'}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <!-- v3.9.0 MINOR P3: Slider visual markers. The Slider
                     stays native (preserves v3.9.0 P2 click-to-seek via
                     IsMoveToPointEnabled + v3.8.0 keyboard arrow bindings
                     + touch). A Canvas overlay is layered on top with
                     Panel.ZIndex=1; IsHitTestTransparent="True" so
                     mouse events pass through to the Slider (the
                     click-to-jump and drag work unchanged). -->
                <Slider x:Name="Scrubber"
                        Minimum="0"
                        Maximum="{Binding ScrubberMaxValue}"
                        Value="{Binding CurrentTimestamp, Mode=TwoWay}"
                        IsEnabled="{Binding IsLoaded}"
                        IsMoveToPointEnabled="True"
                        Thumb.DragCompleted="Scrubber_DragCompleted"/>
                <Canvas x:Name="MarkerCanvas"
                        IsHitTestVisible="False"
                        Panel.ZIndex="1"/>
            </Grid>
            <ComboBox Grid.Column="1"
                      SelectedItem="{Binding Speed, Mode=TwoWay}"
                      Margin="10,0,0,0"
                      Width="80">
                <sys:Double>0.25</sys:Double>
                <sys:Double>0.5</sys:Double>
                <sys:Double>1.0</sys:Double>
                <sys:Double>2.0</sys:Double>
                <sys:Double>4.0</sys:Double>
            </ComboBox>
        </Grid>

        <!-- v1.5.0 MINOR Task 5: Loop CheckBox + CAN ID filter TextBox + inline error.
             UpdateSourceTrigger=PropertyChanged fires the parser on every keystroke. -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox Content="Loop"
                      IsChecked="{Binding Loop}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>
            <TextBlock Text="CAN ID filter:"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0"/>
            <TextBox Text="{Binding CanIdFilterText, UpdateSourceTrigger=PropertyChanged}"
                     Width="200"
                     VerticalAlignment="Center"
                     ToolTip="Comma-separated. Supports 0x prefix hex (e.g. 0x100) and decimal (e.g. 256). Empty = all pass."/>
            <TextBlock Text="{Binding CanIdFilterError}"
                       Foreground="Red"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- v1.5.1 PATCH Task 2: time-range filter (From/To TextBoxes + inline
             error). UpdateSourceTrigger=PropertyChanged fires the validator
             on every keystroke; StringFormat=F3 matches TotalDuration's
             display precision. The range filter is applied at the timeline
             iteration boundary, not the emit boundary. -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="From:"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0"/>
            <TextBox Text="{Binding StartTimestamp, StringFormat=F3, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                     Width="80"
                     VerticalAlignment="Center"
                     ToolTip="Inclusive lower bound on emitted frames' timestamp (seconds from recording start). Empty = unbounded below."/>
            <TextBlock Text="To:"
                       VerticalAlignment="Center"
                       Margin="12,0,4,0"/>
            <TextBox Text="{Binding EndTimestamp, StringFormat=F3, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                     Width="80"
                     VerticalAlignment="Center"
                     ToolTip="Inclusive upper bound on emitted frames' timestamp (seconds from recording start). Empty = unbounded above."/>
            <TextBlock Text="{Binding RangeFilterError}"
                       Foreground="Red"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <TextBlock Grid.Row="5"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- v3.8.0 MINOR chunk 9: Bookmarks + Loop Regions panels.
             Single row at the bottom; two ListBoxes side-by-side.
             No code-behind — pure data binding to the VM's
             ObservableCollections. Manual smoke confirms items
             appear/disappear with AddBookmark/AddLoopRegion/Clear. -->
        <Grid Grid.Row="6" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Bookmarks" FontWeight="Bold" Margin="0,0,0,4"/>
                <!-- v3.9.0 MINOR P4: convert the bookmarks panel from
                     ListBox to DataGrid so the user can double-click a
                     row to edit the label inline. The DataGrid has
                     two columns: Time (read-only, shows Timestamp) +
                     Label (editable, TextBox in CellEditingTemplate).
                     Edits commit on Enter or focus-lost (default
                     DataGrid behavior); the cell setter forwards to
                     Dto.Label so the next bundle save persists the
                     edit. -->
                <DataGrid ItemsSource="{Binding Bookmarks}"
                          MaxHeight="160"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          GridLinesVisibility="None">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time"
                                            Binding="{Binding Timestamp, StringFormat=F3}"
                                            IsReadOnly="True"
                                            Width="80"/>
                        <DataGridTemplateColumn Header="Label" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Label, UpdateSourceTrigger=LostFocus}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Loop Regions" FontWeight="Bold" Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding LoopRegions}" MaxHeight="160"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
