<Window x:Class="PeakCan.Host.App.Views.DbcTreePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PeakCan.Host.App.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:DbcTreePickerViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add signal to watch"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <!-- v3.16.0 MINOR: dialog for picking signals from the loaded DBC.
         Walks DbcService.Current.Messages as a tree (message →
         signal). User checks signals + clicks OK → window returns the
         selection to TraceViewerViewModel.AddToWatch. -->
    <DockPanel Margin="8">
        <!-- Search box -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="50,0,0,0" />
        </Grid>

        <!-- OK / Cancel buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock x:Name="SelectedCountText" VerticalAlignment="Center"
                       Margin="0,0,16,0" Foreground="Gray" />
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True"
                    Click="OnOkClick" />
            <Button Content="Cancel" Width="80" IsCancel="True" />
        </StackPanel>

        <!-- Tree of DBC messages / signals -->
        <TreeView x:Name="Tree" ItemsSource="{Binding Roots}">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <!-- Signal nodes: checkbox + label. v3.16.0 PATCH: Click
                             toggles selection via the code-behind OnSignalCheckClick
                             (the binding-based IsChecked is unreliable on WPF
                             DataTemplate with this TreeView style). -->
                        <CheckBox x:Name="SignalCheck"
                                  Visibility="{Binding IsSignal, Converter={StaticResource BoolToVis}}"
                                  Click="OnSignalCheckClick" />
                        <TextBlock Text="{Binding MessageName}" FontWeight="SemiBold"
                                   Visibility="{Binding IsMessage, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding SignalName}" Margin="4,0,0,0"
                                   Visibility="{Binding IsSignal, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding Unit, StringFormat=' [{0}]'}"
                                   Foreground="Gray"
                                   Visibility="{Binding IsSignal, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</Window>
