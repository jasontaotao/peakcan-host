<Window x:Class="PeakCan.Host.App.Views.TraceViewerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:vm="clr-namespace:PeakCan.Host.App.ViewModels"
        xmlns:trace="clr-namespace:PeakCan.Host.App.Services.Trace"
        xmlns:conv="clr-namespace:PeakCan.Host.App.Composition.Converters"
        d:DataContext="{d:DesignInstance Type=vm:TraceViewerViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Trace Viewer"
        Width="1200" Height="800">
    <DockPanel>
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4">
            <!-- v3.2.0 MINOR: Add trace always appends to the session (never
                 overwrites). Single-trace default behavior unchanged from v3.0.
                 v3.9.1 PATCH Bug #2: switched from Click=OnAddTraceClick to
                 Command={Binding AddTraceCommand} so [NotifyCanExecuteChangedFor]
                 on IsLoading actually gates the button (greys out during load).
                 The Command binding here calls into the same VM method
                 (AddTraceAsync) that the click handler called. -->
            <!-- v3.11.4 PATCH: CommandParameter="" was the regression root cause —
                 it forced AddTraceAsync to receive an empty string, which then
                 tripped PathNormalizer.Normalize's "path must be non-empty" guard.
                 The VM now opens the dialog itself via IFileDialogService. -->
            <Button Content="Add trace…" Command="{Binding AddTraceCommand}"
                    Padding="8,2" Margin="0,0,4,0" />
            <!-- v3.16.0 MINOR: opens DbcTreePickerWindow for the user
                 to pick DBC signals to add to the watch list. -->
            <Button Content="+ Add to watch…" Click="OnAddToWatchClick"
                    Padding="8,2" Margin="0,0,4,0" />
            <!-- v3.15.0 MINOR: loaded DBC path (filename only) shown in
                 the toolbar; full path in tooltip. B1 fix for the
                 "LoadedDbcPath always empty" bug. -->
            <TextBlock VerticalAlignment="Center" Margin="8,0,4,0"
                       Foreground="Gray"
                       Text="{Binding LoadedDbcPathDisplay}"
                       ToolTip="{Binding LoadedDbcPath}" />
            <!-- v3.13.0 PATCH F3: removed "Load DBC…" toolbar button. DbcView
                 tab is the single entry point for DBC loading (the Trace
                 Viewer still reads _dbcService.Current for decoding — no
                 behavior change). -->
            <!-- v3.6.0 MINOR T3: Save/Open .tmtrace session buttons moved to
                 the AppShell File menu (Open Session... / Save Session... +
                 Open Recent submenu). The toolbar buttons are removed; the
                 underlying TraceViewerViewModel.SaveSessionAsync /
                 OpenSessionAsync methods remain public and are now called
                 from AppShellViewModel via DI. -->
            <Separator />

            <!-- v3.3.0 MINOR: master picker (the "clock source") -->
            <TextBlock Text="Master:" VerticalAlignment="Center" Margin="8,0,4,0" />
            <ComboBox Width="180" Margin="0,0,8,0" VerticalAlignment="Center"
                      ItemsSource="{Binding Sources}"
                      SelectedValuePath="SourceId"
                      SelectedValue="{Binding MasterSourceId, Mode=TwoWay}"
                      DisplayMemberPath="DisplayName"
                      ToolTip="Clock source for multi-trace sync playback"
                      Visibility="{Binding HasSources, Converter={StaticResource BoolToVis}}" />

            <Separator />
            <!-- v3.50.4 PATCH: Filter CAN IDs UI HIDDEN (Visibility=Collapsed)
                 — user direction 2026-07-15: "Filter CAN IDs 这块是干嘛的"
                 → user unknown = unused. Hide (not delete) so 1-line restore
                 possible. VM CanIdFilter field, OnCanIdFilterChanged hook,
                 RefreshFrameCounts filter logic all preserved (other tests
                 rely on the field, and the field is still rehydratable from
                 .tmtrace). To restore: remove the Visibility=Collapsed lines
                 on the 3 elements below. -->
            <TextBlock Text="Filter CAN IDs:" VerticalAlignment="Center" Margin="0,0,4,0"
                       Visibility="Collapsed" />
            <TextBox Text="{Binding CanIdFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Width="180" VerticalAlignment="Center" Margin="0,0,4,0"
                     ToolTip="Comma-separated CAN IDs to show (decimal or 0x-hex). Empty = all frames."
                     Visibility="Collapsed" />
            <Button Content="Clear" Command="{Binding ClearCanIdFilterCommand}"
                    Padding="6,2" Margin="0,0,4,0" ToolTip="Clear filter (show all frames)"
                    Visibility="Collapsed" />

            <!-- v3.50.4 PATCH: playback controls REMOVED — user-marked
                 deprecated (2026-07-15: "废弃" = 永久删除). Loop /
                 Speed / ▶ / ⏸ / ⏹ / Scrubber 全部 移除. Trace Viewer
                 从此是只读图表面板 (只支持绿/蓝锚点查值 + watch list),
                 不再含回放控制. 任何残余 PlayCommand/PauseCommand/
                 StopCommand/Loop/Speed/ScrubberValue 在 VM 端保留
                 (其他测试可能 mock), 仅 UI 不再暴露. -->
            <!-- v3.50.2 PATCH T3: anchor visibility toggles. Green = current
                 anchor (the line the user drags to inspect a moment in the
                 trace). Blue = comparison anchor (drag a second time to
                 see how each watched signal has changed between the two
                 moments). Soft-hide (stroke thickness = 0) when unchecked;
                 anchor state preserved so re-show restores the line at
                 the same X. -->
            <!-- v3.50.4 PATCH: shortened labels ("● 当前" / "● 比较")
                 — user reported "显示当前锚点/显示比较锚点 太占地方";
                 shorter labels fit in toolbar 1-screen at narrower window
                 widths. Tooltip preserves the full description. -->
            <ToggleButton Content="● 当前"
                          IsChecked="{Binding IsGreenLineVisible, Mode=TwoWay}"
                          Padding="6,2" Margin="4,0,0,0"
                          ToolTip="当前锚点: 绿线, 拖动设 anchor 时刻, watch list Latest 列读该时刻解码值" />
            <ToggleButton Content="● 比较"
                          IsChecked="{Binding IsBlueLineVisible, Mode=TwoWay}"
                          Padding="6,2" Margin="4,0,0,0"
                          ToolTip="比较锚点: 蓝线, 右键设第二个 anchor, watch list Blue 列读该时刻解码值, Δ = Blue - 当前" />
            <Separator />
            <!-- v3.52.0 MINOR: Lock anchor + Run analysis. Per spec D2: 锁定 requires
                 both green AND blue anchors set; button greys out until then. -->
            <Button Content="🔒 锁定 anchor 状态" Command="{Binding LockAnchorCommand}"
                    Padding="8,2" Margin="4,0,0,0"
                    ToolTip="锁定当前绿/蓝锚状态为 evidence snapshot 起点（必须双锚齐全）" />
            <Button Content="🤖 运行分析" Command="{Binding RunAnalysisCommand}"
                    Padding="8,2" Margin="4,0,0,0"
                    ToolTip="运行本地 AI 推理分析（P0 仅本地特征；P1 接 LLM）" />
        </StackPanel>

        <!-- v3.2.0 MINOR: per-source legend strip. Each entry shows a colored
             swatch (the source's palette color), the display name, and an
             ✕ button to unload the source via RemoveTraceCommand. Hidden
             when no sources are loaded. -->
        <Border DockPanel.Dock="Top" Background="#F4F4F4" Padding="6,4"
                Visibility="{Binding HasSources, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding Sources}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type trace:TraceSource}">
                        <Border Background="White" BorderBrush="#CCC" BorderThickness="1"
                                CornerRadius="3" Padding="6,2" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal">
                                <!-- v3.11.7 PATCH: v3.11.6 PATCH shipped a MultiBinding
                                     with ConvertBack that threw NotSupportedException.
                                     RadioButton.IsChecked is a TwoWay DP by default,
                                     so WPF invoked ConvertBack during the initial
                                     Activate() path; the throw bubbled up through
                                     PropertyPathWorker.CheckReadOnly → MultiBindingExpression.
                                     AttachBindingExpression and surfaced as XamlParseException
                                     AFTER the first asc load (when the per-source legend
                                     DataTemplate materialized). Fix: set Mode="OneWay" on
                                     the MultiBinding so WPF never calls ConvertBack. -->
                                <RadioButton GroupName="MasterGroup" Margin="0,0,6,0" VerticalAlignment="Center"
                                             Command="{Binding DataContext.SetMasterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                             CommandParameter="{Binding SourceId}"
                                             ToolTip="Make this the master (clock source)">
                                    <RadioButton.IsChecked>
                                        <MultiBinding Converter="{x:Static conv:SourceIdEqualsMasterConverter.Instance}"
                                                      Mode="OneWay">
                                            <Binding Path="SourceId"/>
                                            <Binding Path="DataContext.MasterSourceId"
                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </RadioButton.IsChecked>
                                </RadioButton>
                                <Rectangle Width="14" Height="14" Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           Fill="{Binding Color, Converter={StaticResource OxyColorToBrush}}" />
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                <!-- v3.4.3 PATCH: per-source CAN ID filter (override global when
                                     non-empty; inherit global when empty). Width 80 keeps the legend
                                     row compact; tooltip explains the override vs inherit semantics. -->
                                <TextBox Text="{Binding CanIdFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" Margin="6,0,0,0" Padding="2,0" VerticalAlignment="Center"
                                         ToolTip="Per-source filter (decimal or 0x-hex CAN IDs, comma-separated). Empty = inherit global." />
                                <Button Content="✕" Margin="6,0,0,0" Padding="4,0"
                                        Command="{Binding DataContext.RemoveTraceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding SourceId}"
                                        ToolTip="Unload this trace" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Status bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical" Margin="4">
            <!-- v3.9.1 PATCH Bug #2: bind to VM's StatusMessage (lifecycle
                 status: "Loading foo.asc…" / "Loaded foo.asc" / "Load failed" /
                 "Load cancelled"). Gray text, plain font. -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" />
            <!-- v3.9.1 PATCH Bug #2: bind to VM's ErrorMessage (parse failure
                 detail). Red text, bold to distinguish from status line. Hidden
                 via empty-string → DataTrigger if needed; currently always
                 visible but empty when no error. -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#D62728"
                       FontWeight="SemiBold" TextWrapping="Wrap" />
        </StackPanel>

        <!-- v3.50.1 PATCH-A: Recording Expander removed (reverts v3.49 Q2).
             Trace Viewer = offline .asc playback; Recording = live bus capture.
             Two different data sources + lifecycle + DI consumers; sharing a
             window conflated the two concerns. Recording controls restored
             to AppShell View menu (see AppShell.xaml Record menu item). -->

        <!-- Main split: chart subplots (left, expanding) + watch/sampling side panel (right, always visible) -->
        <!-- v3.50.4 PATCH: watch list moved from left column 0 to right
             side panel (TabControl with Sampling Table). User feedback:
             window resize hid the left-column watch list's DataGrid
             scrollbars; right-side dock keeps the watch list + sampling
             table always visible regardless of window width. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="400" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="360" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- Left: chart subplots (per-signal PlotViews) -->
            <ScrollViewer x:Name="ChartScroll" Grid.Column="0" VerticalScrollBarVisibility="Auto"
                          Loaded="OnChartScrollLoaded" SizeChanged="OnChartScrollSizeChanged">
                <ItemsControl ItemsSource="{Binding ChartViewModel.Series}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="0,4">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="8,0">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                        <Button Content="[Focus]" Click="OnFocusSubplotClick" Margin="8,0,4,0" Padding="4,0" />
                                        <Button Content="[▼ Collapse]" Click="OnCollapseSubplotClick" Margin="0,0,4,0" Padding="4,0" />
                                    </StackPanel>
                                    <!-- v3.50.0 MINOR T3: PlotView drag handler.
                                         Background=Transparent is REQUIRED so the
                                         PlotView captures MouseLeftButtonDown
                                         (default Background=null lets the event
                                         fall through to the parent panel).
                                         PreviewMouseLeftButtonDown+Move commits
                                         the anchor at every drag tick; PreviewMouseLeftButtonUp
                                         clears the hover-capture flag. Forwarded
                                         to vm.RefreshAtAnchor(x) where x = the
                                         X-axis inverse-transform of pos.X.
                                         v3.50.2 PATCH T3: right-button drag
                                         commits the BLUE comparison anchor
                                         (sister of the v3.50 green-anchor
                                         handler). -->
                                    <oxy:PlotView Model="{Binding PlotModel}"
                                                  Controller="{Binding Controller}"
                                                  Height="{Binding AdaptiveHeight}"
                                                  Background="Transparent"
                                                  PreviewMouseLeftButtonDown="OnPlotViewMouseDown"
                                                  PreviewMouseLeftButtonUp="OnPlotViewMouseUp"
                                                  PreviewMouseMove="OnPlotViewMouseMove"
                                                  PreviewMouseRightButtonDown="OnPlotViewRightButtonDown" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CCC" />

            <!-- Right: side panel with Watch List + Sampling Table tabs.
                 v3.50.4 PATCH: was two separate right-side panels
                 (Sampling Table in column 4, Watch List in column 0).
                 User reported: "watch list 滚动栏能放到显示窗口的右边么
                 (别窗口大小改变了就找不到了)" — left-column watch list
                 DataGrid scrollbars disappeared when the window shrank
                 below ~1000px. TabControl keeps both panels docked on
                 the right, scrollbars always reachable via window's
                 right edge. -->
            <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1,0,0,0">
                <TabControl>
                    <!-- Tab 1: Watch List (v3.15.0 MINOR source of truth).
                         Always visible regardless of window size. -->
                    <TabItem Header="Watch List">
                        <DataGrid ItemsSource="{Binding WatchedSignals}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  ScrollViewer.CanContentScroll="True"
                                  RowHeight="22">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CAN ID" Binding="{Binding CanIdHex}" Width="64" />
                                <DataGridTextColumn Header="Signal" Binding="{Binding SignalName}" Width="*" />
                                <DataGridTemplateColumn Header="Plot" Width="36">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsPlotted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Click="OnPlotCheckboxClick"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="N" Binding="{Binding FrameCount}" Width="32" />
                                <DataGridTextColumn Header="Latest"
                                                    Binding="{Binding LatestText}"
                                                    Width="80" />
                                <!-- v3.50.5 PATCH: enum signals show "—" in Δ
                                     (no subtractable semantics between text labels);
                                     numeric signals keep the F2 diff. The .Text
                                     computed property handles both cases. -->
                                <DataGridTextColumn Header="Δ"
                                                    Binding="{Binding DeltaText}"
                                                    Width="50" />
                                <DataGridTextColumn Header="Blue"
                                                    Binding="{Binding BlueText}"
                                                    Width="80" />
                                <!-- v3.50.4 PATCH: ✕ Remove column. VM has
                                     RemoveFromWatch [RelayCommand] since
                                     v3.15.0 but XAML never bound it. User
                                     direction 2026-07-15: "watch list 无法
                                     remove". Sister pattern of the per-source
                                     legend ✕ button (line ~171) — DataGrid
                                     cell template Button + CommandParameter
                                     = {Binding} (the row). Window-relative
                                     DataContext lookup for the command so
                                     the cell template's row-scoped
                                     DataContext doesn't shadow the VM. -->
                                <DataGridTemplateColumn Header="" Width="28">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" Padding="2,0"
                                                    ToolTip="Remove this watch entry"
                                                    Command="{Binding DataContext.RemoveFromWatchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <!-- Tab 2: Sampling Table (v3.49.0 MINOR Q1). Hidden when
                         no watched signals exist; otherwise always present. -->
                    <TabItem Header="Sampling Table"
                             Visibility="{Binding HasWatchedSignals, Converter={StaticResource BoolToVis}}">
                        <DataGrid ItemsSource="{Binding SamplingRows}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  EnableRowVirtualization="False" RowHeight="22">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Signal" Binding="{Binding SignalName}" Width="*" />
                                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="40" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="60" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <!-- Tab 3: AI Analysis (v3.52.0 MINOR T10). Sister of
                         Watch List + Sampling Table. ContentControl wraps
                         the lazily-loaded UserControl exposed via
                         TraceViewerViewModel.AIPanelContent. Local-only
                         P0: no LLM attribution banner shown inside the
                         panel itself. -->
                    <TabItem Header="AI Analysis">
                        <ContentControl Content="{Binding AIPanelContent}" />
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>