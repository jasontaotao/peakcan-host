{
  "Channel": {
    "SelectedHandle": null
  },
  "Send": {
    "MaxFramesPerSecond": 0
  },
  "Dbc": {
    "MaxFileSizeBytes": 0,
    "MaxMessageCount": 0
  },
  "Path": {
    "AllowedRoots": []
  },
  "Script": {
    "MaxHeapSizeMB": 64,
    "MaxNewSpaceSizeMB": 16,
    "MaxOldSpaceSizeMB": 48
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "PeakCan.Host": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "%LOCALAPPDATA%/PeakCan.Host/logs/peak-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatProvider": "System.Globalization.CultureInfo, System.Globalization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
